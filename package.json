{
  "name": "government-certificate-brokerage-service",
  "version": "1.0.0",
  "description": "Backend API for a Government Certificate & Brokerage Service Platform.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "lsof -t -i:5001 | xargs kill -9 2>/dev/null || true; nodemon server.js",
    "lint": "eslint .",
    "test": "node --test tests/integration/",
    "test:all": "for file in tests/integration/*.test.js; do node --test \"$file\" || exit 1; done",
    "seed:showcase": "node scripts/seed/index.js --showcase",
    "seed:showcase:reset": "node scripts/seed/index.js --showcase --reset",
    "seed:admin": "node scripts/seedAdmin.js",
    "seed:services": "node scripts/seedServices.js",
    "worker": "node worker.js"
  },
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "government-services",
    "certificates"
  ],
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "@aws-sdk/s3-request-presigner": "^3.1083.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "http-status": "^1.7.4",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.5.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "pino": "^9.3.2",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^9.8.0",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  }
}
