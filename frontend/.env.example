# ============================================================================
# FRONTEND API CONFIGURATION
# ============================================================================

# Development (Backend running locally)
VITE_API_BASE_URL=http://localhost:5001/api/v1

# Production (Vercel Backend URL)
# VITE_API_BASE_URL=https://sevasetu-backend.vercel.app/api/v1

# ============================================================================
# BUILD & DEPLOYMENT NOTES
# ============================================================================
# - This file defines environment variables for the Vite build process
# - Variables must start with VITE_ to be exposed to the frontend
# - Never commit .env files to Git
# - Add VITE_API_BASE_URL to Vercel project environment variables
# - After backend deployment, update VITE_API_BASE_URL with the production URL
