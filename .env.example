# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================
NODE_ENV=development
PORT=5001

APP_NAME="Government Certificate Brokerage Service"
API_VERSION=v1
LOG_LEVEL=info

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Local Development (MongoDB running on localhost)
MONGODB_URI=mongodb://127.0.0.1:27017/gov_certificate_brokerage

# Production (MongoDB Atlas - use your connection string)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gov_certificate_brokerage?retryWrites=true&w=majority
MONGODB_MAX_POOL_SIZE=10

# ============================================================================
# AUTHENTICATION & SECURITY (Generate strong random strings for production)
# ============================================================================
JWT_ACCESS_SECRET=replace-with-a-strong-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-strong-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption key for sensitive delivery data (must be exactly 32 characters)
DELIVERY_SECRET_ENCRYPTION_KEY=your-32-character-encryption-key-here

# Cron job security token (protect scheduled background jobs)
CRON_SECRET=my_secure_cron_secret_replace_in_production

# ============================================================================
# FRONTEND & CORS CONFIGURATION
# ============================================================================
# Development
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:3000

# Production (Vercel Frontend URL)
# FRONTEND_URL=https://sevasetu-frontend.vercel.app
# CORS_ORIGIN=https://sevasetu-frontend.vercel.app

# ============================================================================
# RATE LIMITING & REQUEST HANDLING
# ============================================================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
REQUEST_BODY_LIMIT=10kb

# ============================================================================
# TOKEN & VERIFICATION CONFIGURATION
# ============================================================================
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24

# ============================================================================
# FILE UPLOAD CONFIGURATION
# ============================================================================
UPLOAD_MAX_FILE_SIZE_BYTES=5242880
UPLOAD_MAX_FILES_PER_APPLICATION=10
STORAGE_ROOT=./storage

# ============================================================================
# EMAIL CONFIGURATION (SMTP)
# ============================================================================
EMAIL_FROM="SevaSetu <onboarding@resend.dev>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Note: For Gmail, generate an App Password at https://myaccount.google.com/apppasswords
# For Resend: Verify a domain at https://resend.com/domains
# For SendGrid: Get credentials at https://app.sendgrid.com/settings/api_keys

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================
# Local Storage (Development only - ephemeral on Vercel)
STORAGE_PROVIDER=local

# S3 Compatible Storage (Required for Production on Vercel)
# Option 1: Cloudflare R2
S3_REGION=auto
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_ACCESS_KEY_ID=<your-r2-access-key>
S3_SECRET_ACCESS_KEY=<your-r2-secret-key>
S3_BUCKET=sevasetu-documents
S3_FORCE_PATH_STYLE=true

# Option 2: AWS S3
# S3_REGION=us-east-1
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_ACCESS_KEY_ID=<your-aws-access-key>
# S3_SECRET_ACCESS_KEY=<your-aws-secret-key>
# S3_BUCKET=sevasetu-documents
# S3_FORCE_PATH_STYLE=false

# ============================================================================
# VERCEL DEPLOYMENT NOTES
# ============================================================================
# - Never commit .env files to Git
# - Add all secrets to Vercel project environment variables
# - Local storage is ephemeral on Vercel; use S3/R2 for production
# - Background workers run via Vercel Cron (see vercel.json)
# - Frontend will be deployed as separate Vercel project
# - FRONTEND_URL and CORS_ORIGIN must match the frontend deployment URL
# - After frontend deployment, update these variables and redeploy backend
